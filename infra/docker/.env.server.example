# Copier en .env.server à côté de docker-compose.server.yml (ne pas committer .env.server).
# Le script bootstrap-server.ps1 crée ce fichier et génère les secrets si absent.

POSTGRES_PASSWORD=remplace_par_un_mot_de_passe_fort
JWT_SECRET=remplace_par_un_secret_long_et_aleatoire

# Clé sync (même valeur local + GCP pour le métronome)
SYNC_API_KEY=remplace_par_une_cle_sync_longue

