# Flavor desktop : server (localhost:3000) ou remote (GCP + probe local 2 s).
# VITE_APP_EDITION=server
# VITE_APP_EDITION=remote
#
# Optionnel : surcharge au build (CI, autre serveur). Sinon l’app résout l’URL
# selon l’édition (voir src/renderer/config/resolve-api-base-url.ts).
# VITE_API_URL=https://api.exemple.com
