# Copiez ce fichier en .env pour pointer l'app vers un backend local pendant le développement.
# Si absent, l'app utilise par défaut le backend GCP de production (http://34.118.154.220).
# Exemple pour un backend lancé en local (npm run start:dev dans apps/backend) :
# EXPO_PUBLIC_API_URL=http://192.168.1.50:3000
EXPO_PUBLIC_API_URL=
