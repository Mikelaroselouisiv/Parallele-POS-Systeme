# Connexion PostgreSQL locale (doit commencer par postgresql://).
# Si vous avez l erreur P6001 / prisma://, regenerez le client avec: npm run prisma:generate
# (sans --no-engine, qui force Prisma Accelerate / Data Proxy).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pos_db?schema=public"
JWT_SECRET="super_secret_change_me"
PORT=3000
