# PostgreSQL sur l'EC2 (meme base que la prod) via tunnel SSH — flux par defaut du projet.
# 1) Laisser ouvert : infra/scripts/ec2-db-tunnel.ps1 -PemPath "..." -Ec2Host "IP_EC2"
# 2) Port local du script = 15432 par defaut (mot de passe = celui de docker-compose.prod.yml).
#
# Si vous avez l erreur P6001 / prisma://, regenerez le client avec: npm run prisma:generate
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:15432/pos_db?schema=public"

# --- Option : Postgres uniquement sur votre PC (sans tunnel) ---
# docker compose -f infra/docker/docker-compose.local-postgres.yml up -d
# puis : DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pos_db?schema=public"
JWT_SECRET="super_secret_change_me"
PORT=3000
