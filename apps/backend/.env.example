# Dev local (par défaut) : Postgres sur la machine — ex. `docker compose -f infra/docker/docker-compose.local-postgres.yml up -d`
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/pos_db?schema=public"

# --- Option : même base que l’EC2 via tunnel SSH (port 15432) ---
# infra/scripts/ec2-db-tunnel.ps1 … puis :
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:15432/pos_db?schema=public"

# Si vous avez l erreur P6001 / prisma://, regenerez le client avec: npm run prisma:generate
JWT_SECRET="super_secret_change_me"
PORT=3000
